# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ai-chat-app
JWT_SECRET=your_jwt_secret_key_here

# Hugging Face API Configuration
# Get your API key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_actual_huggingface_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# INSTRUCTIONS:
# 1. Copy this file to .env (remove .example extension)
# 2. Replace "your_actual_huggingface_api_key_here" with your real Hugging Face API key
# 3. Make sure your .env file is in the backend directory
