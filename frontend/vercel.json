{
    "experimentalServices": {
        "rewrites":{
            {
                "source": "/api/:path*",
                "destination": "/_/backend/api/:path*"
            }
        },
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    }
}